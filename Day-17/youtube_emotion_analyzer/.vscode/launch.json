{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Analyse YouTube Video",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": [
        "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Analyse YouTube Video (no chart)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": [
        "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
        "--no-chart"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Analyse YouTube Video (verbose)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": [
        "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
