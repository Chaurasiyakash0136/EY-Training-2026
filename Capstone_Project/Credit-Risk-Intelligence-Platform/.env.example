# .env.example — Credit Risk Intelligence Platform
# ============================================================
# Copy this file to .env:  cp .env.example .env
# Then fill in your actual API keys.
#
# NEVER commit .env to git — it contains secret keys!
# ============================================================


# ════════════════════════════════════════════════════════════
# SECTION 1 — LLM PROVIDERS  (required: fill in at least ONE)
# ════════════════════════════════════════════════════════════

# ── Gemini (PRIMARY — recommended, free tier available) ──────
# How to get your free Gemini key:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Click "Create API key" → "Create API key in new project"
#   3. Copy the key and paste below
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.1

# ── OpenAI (EMBEDDINGS — required regardless of LLM choice) ─
# How to get your OpenAI key:
#   1. Go to https://platform.openai.com/api-keys
#   2. Click "Create new secret key"
#   3. Copy it — you can only see it once!
#   Note: You need a paid account (even $5 credit works)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1

# ── Provider selection ────────────────────────────────────────
# LLM_PROVIDER: which model generates text (gemini or openai)
# EMBEDDING_PROVIDER: which model creates vector embeddings (openai recommended)
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=openai


# ════════════════════════════════════════════════════════════
# SECTION 2 — VECTOR STORE (choose FAISS or Pinecone)
# ════════════════════════════════════════════════════════════

# For development/local use → use faiss (no setup needed)
# For production/cloud use → use pinecone (see Pinecone setup below)
VECTOR_STORE_PROVIDER=faiss
FAISS_INDEX_PATH=data/vectorstore/faiss_index

# ── Pinecone (optional — for production deployment) ──────────
# How to set up Pinecone (free tier: 1 index, 1GB storage):
#   1. Go to https://app.pinecone.io → Sign Up (free)
#   2. Create an API key under "API Keys"
#   3. Create an index named "credit-risk-platform":
#      - Dimensions: 1536  (matches text-embedding-3-small)
#      - Metric: cosine
#      - Region: us-east-1 (or your nearest)
#   4. Fill in the values below and set VECTOR_STORE_PROVIDER=pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=credit-risk-platform
PINECONE_REGION=us-east-1


# ════════════════════════════════════════════════════════════
# SECTION 3 — LANGSMITH OBSERVABILITY (optional, free)
# ════════════════════════════════════════════════════════════
# LangSmith traces every LLM call, embedding, and retrieval.
# Great for debugging and improving your RAG pipeline.
#
# How to enable:
#   1. Go to https://smith.langchain.com → Sign Up (free)
#   2. Create a project called "credit-risk-platform"
#   3. Go to Settings → API Keys → Create API key
#   4. Paste key below and set LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=credit-risk-platform
LANGCHAIN_TRACING_V2=false


# ════════════════════════════════════════════════════════════
# SECTION 4 — EVALUATION (optional, backend only)
# ════════════════════════════════════════════════════════════
# Enables RAGAS + DeepEval automatic quality scoring after each chat.
# Results saved to logs/eval_scores.jsonl (not visible in UI).
#
# How to enable:
#   1. Install: pip install ragas deepeval datasets
#   2. DeepEval free key: https://app.confident-ai.com → Sign Up
#   3. Set EVALUATION_ENABLED=true
EVALUATION_ENABLED=false
DEEPEVAL_API_KEY=your_deepeval_api_key_here


# ════════════════════════════════════════════════════════════
# SECTION 5 — APPLICATION (usually no changes needed)
# ════════════════════════════════════════════════════════════
APP_TITLE=Credit Risk Intelligence Platform
APP_ENV=development
LOG_LEVEL=INFO

# ── RAG tuning ────────────────────────────────────────────────
# These are already optimised — only change if you're experimenting
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=6
RETRIEVER_USE_MMR=true

# Embedding dimension — MUST match your Pinecone index's dimension exactly.
# If you created your Pinecone index with dimension=1024, set this to 1024.
# If you created it with dimension=1536, set this to 1536.
# Only used when EMBEDDING_PROVIDER=openai with a text-embedding-3-* model.
OPENAI_EMBEDDING_DIMENSIONS=1024

# ════════════════════════════════════════════════════════════
# SECTION 4b — HYBRID SEARCH & RE-RANKING (v3.0 — hallucination fixes)
# ════════════════════════════════════════════════════════════
# These were added to fix cross-year hallucinations found in evaluation.
# Safe to leave as default (true) — only disable if troubleshooting.
HYBRID_SEARCH_ENABLED=true
RERANK_ENABLED=true

# ════════════════════════════════════════════════════════════
# SECTION 4c — AUTHENTICATION (v3.0 — required)
# ════════════════════════════════════════════════════════════
# JWT_SECRET_KEY: any random 64-character string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# CHANGE THIS before any real deployment — the default is NOT secure.
JWT_SECRET_KEY=change-this-to-a-random-64-char-string-before-deploying
SESSION_EXPIRY_HOURS=24

# ── Email (optional — for password reset / verification) ──────
# Leave blank to safely log emails to logs/dev_emails.log instead of
# sending real emails (fine for local testing). To send REAL emails:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your_email@gmail.com
#   SMTP_PASSWORD=your_16_char_gmail_app_password   (NOT your real password —
#     generate one at https://myaccount.google.com/apppasswords)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── FastAPI (optional REST layer) ─────────────────────────────
# Run: uvicorn src.api.main:app --port 8000
API_PORT=8000
API_KEY=

# ── OCR for scanned PDFs (optional) ──────────────────────────
OCR_ENABLED=true
OCR_MIN_CHARS_PER_PAGE=50

# ── Retirement Planner defaults ───────────────────────────────
RETIREMENT_DEFAULT_RETURN=14.0
RETIREMENT_DEFAULT_INFLATION=6.0
RETIREMENT_DEFAULT_LIFE_EXP=80
