# ============================================================
# Credit Risk Intelligence Platform — Environment Configuration
# ============================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your API keys below
#   3. Never commit .env to version control (it is in .gitignore)
# ============================================================

# ------------------------------------------------------------------
# HYBRID AI CONFIGURATION
# LLM_PROVIDER       = which AI model ANSWERS questions and generates text
# EMBEDDING_PROVIDER = which AI model creates VECTOR EMBEDDINGS for search
# These are INDEPENDENT — recommended: Gemini for LLM + OpenAI for embeddings
# ------------------------------------------------------------------
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=openai

# ------------------------------------------------------------------
# OpenAI  (used for embeddings — text-embedding-3-small)
# Get key: https://platform.openai.com/api-keys
# Cost: ~$0.0001 per document uploaded (very cheap)
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=2048

# ------------------------------------------------------------------
# Google Gemini  (used for LLM chat, summarisation, risk analysis)
# Get key: https://aistudio.google.com/app/apikey
# Free tier available — no credit card required for basic usage
# ------------------------------------------------------------------
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=2048

# ------------------------------------------------------------------
# FAISS Vector Store  (free, local — no cloud service needed)
# ------------------------------------------------------------------
FAISS_INDEX_PATH=data/vectorstore/faiss_index
CHUNK_SIZE=600
CHUNK_OVERLAP=250
RETRIEVER_TOP_K=12

# ------------------------------------------------------------------
# OCR (Tesseract) — for scanned / image-based PDFs
# See TESSERACT_INSTALL.md for installation instructions
# Set OCR_ENABLED=false if Tesseract is NOT installed on your system
# ------------------------------------------------------------------
OCR_ENABLED=true
# Windows only: uncomment and set the path to tesseract.exe
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Mac/Linux: leave commented out (auto-detected from PATH)
OCR_MIN_CHARS_PER_PAGE=50

# ------------------------------------------------------------------
# LangSmith Observability  (free tier: 5,000 traces/month)
# Get key: https://smith.langchain.com → Settings → API Keys
# When set, ALL LLM calls are automatically traced — no code changes needed
# ------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=credit-risk-platform

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
APP_TITLE=Credit Risk Intelligence Platform
APP_ENV=development
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
DATA_UPLOAD_DIR=data/uploads

# ------------------------------------------------------------------
# Future: Azure Services (not implemented in MVP)
# ------------------------------------------------------------------
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_KEY=
